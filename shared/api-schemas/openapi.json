      "RunSimulationRequest": {
        "type": "object",
        "description": "Seed assets for simulation. Send non-empty triggerAssetIds (preferred) and/or legacy triggerAssetId. Server dedupes and trims; if both are present, non-empty triggerAssetIds wins. At least one seed is required (validated server-side). Multiple seeds cannot be combined with a non-null patch that carries meaningful fields (MVP).",
        "properties": {
          "triggerAssetId": {
            "type": "string",
            "description": "Legacy single seed. Normalized to a one-element list when triggerAssetIds is absent or empty."
          },
          "triggerAssetIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "description": "Canonical multi-seed list. When non-empty, takes precedence over triggerAssetId."
          },
          "patch": {
            "allOf": [
              {
                "$ref": "#/components/schemas/StatePatchDto"
              }
            ],
            "nullable": true
          },
          "maxDepth": {
            "type": "integer",
            "description": "BFS depth cap; omit or ≤0 to use server default (leaf-oriented, typically 100).",
            "default": 0
          },
          "runTick": {
            "type": "integer",
            "default": 0
          },
          "engineTickIntervalMs": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5000,
            "default": 1000,
            "description": "Continuous simulation engine polling interval (ms)."
          },
          "resetState": {
            "type": "boolean",
            "default": false,
            "description": "When true, deletes persisted Mongo states for all participating assets before the run (skipped for what-if dry runs). Re-seeds from asset/schema baseline. Event history is not deleted."
          }
        }
      },
