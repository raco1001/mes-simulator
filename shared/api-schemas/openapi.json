  "components": {
    "schemas": {
      "AssetDto": {
        "type": "object",
        "required": [
          "id",
          "type",
          "connections",
          "metadata",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "connections": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "StateDto": {
        "type": "object",
        "required": [
          "assetId",
          "status",
          "updatedAt",
          "metadata"
        ],
        "properties": {
          "assetId": {
            "type": "string"
          },
          "currentTemp": {
            "type": "number",
            "nullable": true
          },
          "currentPower": {
            "type": "number",
            "nullable": true
          },
          "status": {
            "type": "string",
            "enum": [
              "normal",
              "warning",
              "error"
            ]
          },
          "operationalStatus": {
            "type": "string",
            "nullable": true,
            "description": "Pipeline-derived operational status (Phase 21)."
          },
          "simulationStatus": {
            "type": "string",
            "nullable": true,
            "description": "Simulation-layer status when present."
          },
          "lastEventType": {
            "type": "string",
            "nullable": true
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "PropertyMapping": {
        "type": "object",
        "required": [
          "fromProperty",
          "toProperty"
        ],
        "properties": {
          "fromProperty": {
            "type": "string",
            "description": "source asset property key"
          },
          "toProperty": {
            "type": "string",
            "description": "target asset property key"
          },
          "transformRule": {
            "type": "string",
            "description": "Transform expression. Supported: 'value', 'value * N', 'value / N', 'value + N', 'value - N'",
            "default": "value"
          },
          "fromUnit": {
            "type": "string",
            "nullable": true
          },
          "toUnit": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "RelationshipDto": {
        "type": "object",
        "required": [
          "id",
          "fromAssetId",
          "toAssetId",
          "relationshipType",
          "properties",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "fromAssetId": {
            "type": "string"
          },
          "toAssetId": {
            "type": "string"
          },
          "relationshipType": {
            "type": "string"
          },
          "properties": {
            "type": "object",
            "additionalProperties": true
          },
          "mappings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PropertyMapping"
            },
            "default": [],
            "description": "Property mappings for Supplies propagation. When empty, legacy properties.transfers TransferSpec is used."
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateAssetRequest": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "connections": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "UpdateAssetRequest": {
        "type": "object",
