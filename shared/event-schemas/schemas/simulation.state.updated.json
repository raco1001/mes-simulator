{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Simulation State Updated Event",
  "description": "시뮬레이션 전파 과정에서 Asset 상태가 갱신되었음을 나타내는 이벤트",
  "allOf": [
    { "$ref": "event-envelope.json" },
    {
      "type": "object",
      "properties": {
        "eventType": {
          "type": "string",
          "const": "simulation.state.updated",
          "description": "이벤트 타입 식별자"
        },
        "payload": {
          "oneOf": [
            { "$ref": "#/definitions/NodeUpdatePayload" },
            { "$ref": "#/definitions/PropagationPayload" },
            { "$ref": "#/definitions/StatePropertiesPayload" }
          ]
        }
      }
    }
  ],
  "definitions": {
    "NodeUpdatePayload": {
      "type": "object",
      "required": ["tick", "depth", "status", "temperature", "power"],
      "properties": {
        "tick": {
          "type": "integer",
          "description": "런 내 이벤트 순서 인덱스"
        },
        "depth": {
          "type": "integer",
          "description": "BFS 전파 깊이"
        },
        "status": {
          "type": "string",
          "description": "현재 상태(normal/warning/error)"
        },
        "temperature": {
          "type": "number",
          "description": "현재 온도 값"
        },
        "power": {
          "type": "number",
          "description": "현재 전력 값"
        }
      },
      "additionalProperties": false
    },
    "PropagationPayload": {
      "type": "object",
      "required": ["tick", "depth", "relationshipType", "fromAssetId"],
      "properties": {
        "tick": {
          "type": "integer",
          "description": "런 내 이벤트 순서 인덱스"
        },
        "depth": {
          "type": "integer",
          "description": "BFS 전파 깊이"
        },
        "relationshipType": {
          "type": "string",
          "enum": ["Supplies", "Contains", "ConnectedTo"],
          "description": "전파를 유발한 관계 타입"
        },
        "fromAssetId": {
          "type": "string",
          "description": "전파를 시작한 원본 Asset ID"
        },
        "relationshipId": {
          "type": "string",
          "description": "관계 식별자 (있는 경우)"
        }
      },
      "additionalProperties": false
    },
    "StatePropertiesPayload": {
      "type": "object",
      "description": "Phase 21: 동적 properties + 선택적 델타. 백엔드 전파 노드 이벤트 기본 형태.",
      "required": ["tick", "depth", "properties"],
      "properties": {
        "tick": { "type": "integer" },
        "tickIndex": {
          "type": "integer",
          "description": "Run 전역 tick (tick과 동일하면 생략 가능)"
        },
        "depth": { "type": "integer" },
        "properties": {
          "type": "object",
          "additionalProperties": true
        },
        "propertyChanges": {
          "type": "object",
          "description": "키별 { from, to } 변경분",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "from": {},
              "to": {}
            },
            "additionalProperties": true
          }
        },
        "simulationStatus": {
          "type": "string",
          "description": "백엔드 시뮬 병합 상태(운영 임계 판정과 분리)"
        },
        "status": {
          "type": "string",
          "description": "레거시: simulationStatus와 동일 용도로 발행될 수 있음"
        },
        "relationshipType": { "type": "string" },
        "fromAssetId": { "type": "string" },
        "relationshipId": { "type": "string" },
        "cycleAccumulated": { "type": "boolean" },
        "deltaSeconds": { "type": "number" }
      },
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "eventType": "simulation.state.updated",
      "assetId": "freezer-1",
      "timestamp": "2026-02-18T10:00:00Z",
      "schemaVersion": "v1",
      "runId": "run-123",
      "payload": {
        "tick": 1,
        "depth": 0,
        "status": "warning",
        "temperature": -5,
        "power": 180
      }
    },
    {
      "eventType": "simulation.state.updated",
      "assetId": "conveyor-1",
      "timestamp": "2026-02-18T10:00:02Z",
      "schemaVersion": "v1",
      "runId": "run-123",
      "payload": {
        "tick": 1,
        "depth": 1,
        "relationshipType": "ConnectedTo",
        "fromAssetId": "freezer-1",
        "relationshipId": "rel-1"
      }
    },
    {
      "eventType": "simulation.state.updated",
      "assetId": "freezer-01",
      "timestamp": "2026-04-06T12:00:00Z",
      "schemaVersion": "v1",
      "runId": "abc123",
      "payload": {
        "tick": 42,
        "tickIndex": 42,
        "depth": 0,
        "properties": { "powerAvailable": 750 },
        "propertyChanges": {
          "powerAvailable": { "from": 900, "to": 750 }
        },
        "simulationStatus": "warning"
      }
    }
  ]
}
