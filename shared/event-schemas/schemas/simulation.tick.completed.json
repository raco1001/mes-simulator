{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Simulation Tick Completed Event",
  "description": "엔진 루프 한 사이클 완료. 소비자는 이 시점 이후 배치 커밋 가능.",
  "allOf": [
    { "$ref": "event-envelope.json" },
    {
      "type": "object",
      "properties": {
        "eventType": {
          "type": "string",
          "const": "simulation.tick.completed"
        },
        "payload": {
          "type": "object",
          "required": ["tickIndex", "dueAssetIds", "changedAssetIds"],
          "properties": {
            "tickIndex": { "type": "integer" },
            "dueAssetIds": {
              "type": "array",
              "items": { "type": "string" }
            },
            "changedAssetIds": {
              "type": "array",
              "items": { "type": "string" }
            },
            "engineCycleId": { "type": "string" }
          },
          "additionalProperties": true
        }
      }
    }
  ],
  "examples": [
    {
      "eventType": "simulation.tick.completed",
      "assetId": "__engine__",
      "timestamp": "2026-04-06T12:00:00.100Z",
      "schemaVersion": "v1",
      "runId": "abc123",
      "payload": {
        "tickIndex": 5,
        "dueAssetIds": ["asset-a"],
        "changedAssetIds": ["asset-a", "asset-b"],
        "engineCycleId": "abc123:5"
      }
    }
  ]
}
