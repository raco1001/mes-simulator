{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Alert Generated Event",
  "description": "Asset에서 알림이 생성되었을 때 발생하는 이벤트",
  "allOf": [
    { "$ref": "event-envelope.json" },
    {
      "type": "object",
      "properties": {
        "eventType": {
          "type": "string",
          "const": "alert.generated",
          "description": "이벤트 타입 식별자"
        },
        "payload": {
          "type": "object",
          "required": ["severity", "message"],
          "properties": {
            "severity": {
              "type": "string",
              "enum": ["info", "warning", "error", "critical"],
              "description": "알림 심각도"
            },
            "message": {
              "type": "string",
              "description": "알림 메시지"
            },
            "metrics": {
              "type": "array",
              "description": "복수 메트릭 임계치 정보",
              "items": {
                "type": "object",
                "required": ["metric", "current", "threshold", "code", "severity"],
                "properties": {
                  "metric": {
                    "type": "string",
                    "description": "메트릭 이름",
                    "examples": ["temperature", "power", "humidity"]
                  },
                  "current": {
                    "type": "number",
                    "description": "현재 값"
                  },
                  "threshold": {
                    "type": "number",
                    "description": "임계값"
                  },
                  "code": {
                    "type": "string",
                    "description": "알림 코드"
                  },
                  "severity": {
                    "type": "string",
                    "enum": ["warning", "error"],
                    "description": "메트릭 단위 심각도"
                  }
                }
              }
            },
            "metadata": {
              "type": "object",
              "description": "추가 알림 정보 (자유 형식)",
              "additionalProperties": true
            }
          }
        }
      }
    }
  ],
  "examples": [
    {
      "eventType": "alert.generated",
      "assetId": "freezer-1",
      "timestamp": "2026-02-18T10:00:00Z",
      "schemaVersion": "v1",
      "payload": {
        "severity": "warning",
        "message": "Temperature above threshold",
        "metrics": [
          {
            "metric": "temperature",
            "current": -5,
            "threshold": -10,
            "code": "TEMP_HIGH",
            "severity": "warning"
          }
        ]
      }
    },
    {
      "eventType": "alert.generated",
      "assetId": "conveyor-1",
      "timestamp": "2026-02-18T10:05:00Z",
      "schemaVersion": "v1",
      "runId": "abc123def456",
      "payload": {
        "severity": "error",
        "message": "Power consumption exceeded safe limit",
        "metrics": [
          {
            "metric": "power",
            "current": 250,
            "threshold": 200,
            "code": "POWER_OVERLOAD",
            "severity": "error"
          }
        ],
        "metadata": {
          "duration": 300,
          "recommendedAction": "Reduce load or check equipment"
        }
      }
    }
  ]
}
