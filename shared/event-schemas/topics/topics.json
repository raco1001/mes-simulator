{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kafka Topics Definition",
  "description": "Factory MES 시스템의 Kafka 토픽 정의",
  "type": "object",
  "required": ["topics"],
  "properties": {
    "topics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description", "status", "events"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Kafka 토픽 이름 (규칙: {domain}.{entity}.{event})"
          },
          "description": {
            "type": "string",
            "description": "토픽 설명"
          },
          "status": {
            "type": "string",
            "enum": ["active", "planned", "deprecated"],
            "description": "토픽 운영 상태"
          },
          "events": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "이 토픽에서 처리할 이벤트 타입 목록"
          },
          "partitions": {
            "type": "integer",
            "description": "토픽 파티션 수 (기본값: 3)",
            "default": 3,
            "minimum": 1
          },
          "replicationFactor": {
            "type": "integer",
            "description": "복제 팩터 (기본값: 1)",
            "default": 1,
            "minimum": 1
          }
        }
      }
    }
  },
  "topics": [
    {
      "name": "factory.asset.events",
      "description": "실사용 단일 통합 토픽 (asset 이벤트 전체). backend/pipeline 모두 이 토픽만 사용.",
      "status": "active",
      "events": [
        "asset.created",
        "asset.health.updated",
        "simulation.state.updated"
      ],
      "partitions": 3,
      "replicationFactor": 1
    },
    {
      "name": "factory.asset.alert",
      "description": "Alert 전용 토픽. backend alert consumer가 직접 구독한다.",
      "status": "active",
      "events": [
        "alert.generated"
      ],
      "partitions": 3,
      "replicationFactor": 1
    },
    {
      "name": "factory.recommendation.generated",
      "description": "Recommendation 생성 이벤트 토픽.",
      "status": "active",
      "events": [
        "recommendation.generated"
      ],
      "partitions": 3,
      "replicationFactor": 1
    },
    {
      "name": "factory.recommendation.applied",
      "description": "Recommendation 적용 이벤트 토픽.",
      "status": "active",
      "events": [
        "recommendation.applied"
      ],
      "partitions": 3,
      "replicationFactor": 1
    }
  ]
}
