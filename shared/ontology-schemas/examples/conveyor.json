      "constraints": { "min": 0, "max": 5 },
      "required": true
    },
    {
      "key": "throughputPerHour",
      "dataType": "Number",
      "unit": "itemsPerHour",
      "simulationBehavior": "Derived",
      "mutability": "Mutable",
      "baseValue": 400,
      "constraints": { "min": 0 },
